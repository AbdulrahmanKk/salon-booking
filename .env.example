# Supabase — من لوحة المشروع: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Moyasar — من لوحة Moyasar: https://moyasar.com
NEXT_PUBLIC_MOYASAR_PUBLISHABLE_KEY=pk_test_xxxxxxxx
MOYASAR_SECRET_KEY=sk_test_xxxxxxxx

# كلمة مرور صفحة الإدارة (اختياري — اتركها فارغة لتعطيل الحماية في التطوير)
ADMIN_PASSWORD=your-secure-password

# بداية يوم العمل (ساعة 24) — افتراضي 9
BUSINESS_START_HOUR=14
